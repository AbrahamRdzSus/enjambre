{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ENJAMBRE",
  "version": "0.5.0",
  "identifier": "mx.obsidia.enjambre",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ENJAMBRE",
        "width": 1240,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/enjambre-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AbrahamRdzSus/enjambre/releases/latest/download/latest.json"
      ],
      "pubkey": "REEMPLAZAR_CON_LA_CLAVE_PUBLICA_DE_cargo_tauri_signer_generate",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
