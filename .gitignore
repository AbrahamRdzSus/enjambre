# Logs
*.log
npm-debug.log*

# Entorno / secretos
.env
.env.*
!.env.example
*.pem
*.key

# Sistema operativo
.DS_Store
Thumbs.db

# Editores
.vscode/
.idea/
*.swp

# Dependencias y build (generico)
node_modules/
dist/
build/
out/
coverage/
tmp/
.cache/

# Obsidia / despliegue
publish/
ecosystem.config.js
*.keystore
.obsidia-keys/
# Artefactos de build con hash (NO commitear: rompen git pull en deploy)
# **/ para alcanzar wwwroot anidado (src/App.Api/wwwroot/...)
**/wwwroot/*.js
**/wwwroot/*.css

# OMC state
.omc/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# ENJAMBRE runtime (workspaces y logs locales)
/logs/
/projects/
/hub/runtime/

# --- agregado por project-essentials ---
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Sesiones persistidas (enjambre.sessions)
.enjambre/

# Tauri (shell Rust)
tauri/target/
tauri/gen/

# extraccion temporal del export de v0
diseno/_v0cockpit/

# PyInstaller / sidecar congelado (artefactos, se regeneran)
build/
dist/
*.spec
# ...salvo el spec del sidecar: NO es autogenerado, es la receta de empaque
# (hiddenimports, upx) que docs/ROADMAP_E5.md manda ejecutar. Sin el versionado,
# quien clone el repo no puede reconstruir el sidecar.
!enjambre-sidecar.spec
tauri/binaries/*.exe
diseno/e-commerce-nexus-dashboard/
